# Database
DB_PASSWORD=your_secure_password

# JWT
JWT_SECRET=your_jwt_secret_key_minimum_256_bits_long

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id
